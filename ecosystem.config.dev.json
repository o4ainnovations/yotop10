{
  "apps": [
    {
      "name": "frontend-dev",
      "script": "node_modules/next/dist/bin/next",
      "args": "dev -p 3000",
      "cwd": "/app/frontend",
      "watch": false,
      "autorestart": true,
      "max_restarts": 5,
      "min_uptime": "5s",
      "kill_timeout": 3000
    },
    {
      "name": "backend-dev",
      "script": "node_modules/tsx/dist/cli.mjs",
      "args": "watch src/server.ts",
      "cwd": "/app/backend",
      "watch": false,
      "autorestart": true,
      "max_restarts": 5,
      "min_uptime": "5s",
      "kill_timeout": 3000,
      "env": { "PORT": "8000" }
    }
  ]
}
