# ── YoTop10 Environment Template ──
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# For production, use Docker secrets (/run/secrets/) instead of env vars
# for all sensitive values.

# ── REQUIRED: JWT Secret (for admin authentication)
# Generate with: openssl rand -hex 32 (64 characters minimum)
JWT_SECRET=change-me-to-a-64-char-hex-secret

# ── API Domain
NEXT_PUBLIC_API_URL=https://api.yotop10.com
INTERNAL_API_URL=http://backend:8000/api

# ── CORS Allowed Origins
CORS_ORIGINS=https://yotop10.com,https://www.yotop10.com

# ── Database Credentials
MONGO_USERNAME=yotop10_admin
MONGO_ROOT_PASSWORD=change-me
MONGO_PASSWORD=change-me

REDIS_PASSWORD=change-me

ES_PASSWORD=change-me

# ── Nginx Domain
NGINX_SERVER_NAME=yotop10.local

# ── Tunable Constants (optional — defaults shown)
# Rate limit window (default: 1 hour in ms)
RATE_LIMIT_WINDOW_MS=3600000
# Soft delete TTL before permanent removal (default: 30 days in ms)
SOFT_DELETE_TTL_MS=2592000000
