#!/bin/sh
# Pre-commit hook — enforces zero new TypeScript errors + zero lint errors

echo "🔍 Pre-commit checks..."

STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v '\.test\.' | grep -v 'node_modules' | grep -v 'types/')

if [ -z "$STAGED_TS" ]; then
  echo "✅ No application TypeScript files staged."
  exit 0
fi

# ─── Backend typecheck ───────────────────────────────────────────
if [ -d "backend" ] && [ -f "backend/node_modules/.bin/tsc" ]; then
  cd backend
  node_modules/.bin/tsc --noEmit 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ Backend TypeScript compilation failed."
    exit 1
  fi
  echo "✅ Backend typecheck passed."
  cd ..
else
  echo "⚠️  Backend tsc not available locally — CI will enforce."
fi

# ─── Backend lint on staged files ───────────────────────────────
BACKEND_STAGED=$(echo "$STAGED_TS" | grep '^backend/' | tr '\n' ' ')
if [ -n "$BACKEND_STAGED" ] && [ -f "backend/node_modules/.bin/eslint" ]; then
  cd backend
  echo "$BACKEND_STAGED" | xargs node_modules/.bin/eslint --quiet 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ Backend lint failed."
    exit 1
  fi
  echo "✅ Backend lint passed."
  cd ..
fi

# ─── Frontend lint on staged files ──────────────────────────────
FRONTEND_STAGED=$(echo "$STAGED_TS" | grep '^frontend/' | tr '\n' ' ')
if [ -n "$FRONTEND_STAGED" ] && [ -f "frontend/node_modules/.bin/eslint" ]; then
  cd frontend
  echo "$FRONTEND_STAGED" | xargs npx eslint --quiet 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ Frontend lint failed."
    exit 1
  fi
  echo "✅ Frontend lint passed."
  cd ..
fi

echo "✅ All checks passed."
exit 0
