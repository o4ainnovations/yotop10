#!/bin/sh
# Pre-commit hook — secret detection + TypeScript + lint
set -e

echo "🔍 Pre-commit checks..."

# ─── Secret Detection ─────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Patterns that indicate secrets being committed
SECRET_PATTERNS='(JWT_SECRET=|password=|api.key=|api_secret=|secret=|private.key|-----BEGIN.*PRIVATE KEY-----)'

echo "$STAGED_FILES" | while read -r file; do
  if [ -f "$file" ]; then
    MATCHES=$(grep -Ein "$SECRET_PATTERNS" "$file" 2>/dev/null || true)
    if [ -n "$MATCHES" ] && echo "$file" | grep -qv '\.env\.example$'; then
      echo "❌ SECURITY: Potential secret detected in $file"
      echo "$MATCHES" | while read -r line; do
        echo "  $line"
      done
      echo ""
      echo "If this is a legitimate secret, remove it from the file and use"
      echo "Docker secrets (/run/secrets/) or environment variables instead."
      echo "If this is a false positive, add the file path to the exception list."
      exit 1
    fi
  fi
done

# Check staged .env files specifically (they should NEVER be committed)
ENV_STAGED=$(echo "$STAGED_FILES" | grep -E '^\.env$|^backend/\.env$|^frontend/\.env$' || true)
if [ -n "$ENV_STAGED" ]; then
  echo "❌ BLOCKED: .env file should never be committed!"
  echo "   Staged files: $ENV_STAGED"
  echo "   Use .env.example instead (without real secrets)."
  exit 1
fi

STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v '\.test\.' | grep -v 'node_modules' | grep -v 'types/' || true)

if [ -z "$STAGED_TS" ]; then
  echo "✅ No application TypeScript files staged."
  exit 0
fi

DOCKER_EXEC="docker exec yotop10_dev"

# Check if dev container is running
if ! docker ps -q --filter "name=yotop10_dev" | grep -q .; then
  echo "⚠️  Dev container not running — CI will enforce. Commit allowed."
  exit 0
fi

HAS_BACKEND=$(echo "$STAGED_TS" | grep -q '^backend/' && echo 1 || echo 0)
HAS_FRONTEND=$(echo "$STAGED_TS" | grep -q '^frontend/' && echo 1 || echo 0)

# ─── Backend typecheck ───────────────────────────────────────────
if [ "$HAS_BACKEND" = "1" ]; then
  $DOCKER_EXEC sh -c 'cd /app/backend && npx tsc --noEmit' 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "❌ Backend typecheck failed."
    exit 1
  fi
  echo "✅ Backend typecheck passed (Docker)."

  $DOCKER_EXEC sh -c 'cd /app/backend && npx eslint src --ext .ts --quiet' 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "⚠️  Backend lint may have issues — CI will enforce."
  fi
fi

# ─── Frontend typecheck ──────────────────────────────────────────
if [ "$HAS_FRONTEND" = "1" ]; then
  $DOCKER_EXEC sh -c 'cd /app/frontend && npx tsc --noEmit' 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "❌ Frontend typecheck failed."
    exit 1
  fi
  echo "✅ Frontend typecheck passed (Docker)."

  $DOCKER_EXEC sh -c 'cd /app/frontend && ESLINT_USE_FLAT_CONFIG=false npx eslint src/ --quiet' 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "⚠️  Frontend lint may have issues — CI will enforce."
  fi
fi

echo "✅ All checks passed."
exit 0
