#!/bin/sh
# Pre-commit hook — enforces zero new TypeScript errors
# Soft enforcement: skips if tsc not available (host machine)
# Hard enforcement: CI via `pnpm typecheck`

echo "🔍 Checking TypeScript..."

STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v '\.test\.' | grep -v 'node_modules' | grep -v 'types/')

if [ -z "$STAGED_TS" ]; then
  echo "✅ No application TypeScript files staged."
  exit 0
fi

# Try backend tsc (preferred — uses project's TypeScript version)
if [ -d "backend" ] && [ -f "backend/node_modules/.bin/tsc" ]; then
  cd backend
  node_modules/.bin/tsc --noEmit 2>&1
  RESULT=$?
  cd ..
  if [ $RESULT -ne 0 ]; then
    echo ""
    echo "❌ TypeScript compilation failed on staged files."
    echo "   See AGENTS.md Section 3.2."
    exit 1
  fi
  echo "✅ Backend typecheck passed."
elif command -v tsc >/dev/null 2>&1; then
  cd backend 2>/dev/null && tsc --noEmit 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ TypeScript compilation failed."
    exit 1
  fi
  cd ..
  echo "✅ Backend typecheck passed."
else
  echo "⚠️  tsc not available locally — CI will enforce. Commit allowed."
fi

# Check for 'as any' in staged files (fast grep, no deps)
AS_ANY=$(echo "$STAGED_TS" | xargs grep -l 'as any' 2>/dev/null)
if [ -n "$AS_ANY" ]; then
  echo "⚠️  WARNING: 'as any' found in staged files:"
  echo "$AS_ANY"
  echo "   CI may reject. See AGENTS.md Section 3.2."
fi

exit 0
