#!/bin/sh
# Pre-commit hook — enforces zero new TypeScript errors
# Runs tsc --noEmit on staged files only

echo "🔍 Running TypeScript check on staged files..."

# Get staged .ts/.tsx files
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v '\.test\.' | grep -v 'node_modules')

if [ -z "$STAGED" ]; then
  echo "✅ No TypeScript files staged, skipping."
  exit 0
fi

# Run tsc --noEmit (full check — partial checking is unreliable with TS)
cd "$(git rev-parse --show-toplevel)/backend" 2>/dev/null || exit 0

if [ ! -f "package.json" ]; then
  echo "⚠️  Backend not found, skipping typecheck."
  exit 0
fi

# Check if tsc is available
if command -v npx >/dev/null 2>&1; then
  npx tsc --noEmit 2>&1
  RESULT=$?
  if [ $RESULT -ne 0 ]; then
    echo ""
    echo "❌ TypeScript compilation failed. Fix errors before committing."
    echo "   Rule: Every commit must not introduce NEW tsc errors."
    echo "   See AGENTS.md Section 3.2 — Zero-Error Incremental Policy."
    exit 1
  fi
  echo "✅ TypeScript check passed."
else
  echo "⚠️  tsc not available, skipping typecheck."
fi

exit 0
