#!/bin/sh
# Pre-commit hook — enforces zero new TypeScript + zero lint errors
# Runs checks inside Docker container when available (tsc/eslint live there)

echo "🔍 Pre-commit checks..."

STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v '\.test\.' | grep -v 'node_modules' | grep -v 'types/')

if [ -z "$STAGED_TS" ]; then
  echo "✅ No application TypeScript files staged."
  exit 0
fi

DOCKER_EXEC="docker exec yotop10_dev"

# Check if dev container is running
if ! docker ps -q --filter "name=yotop10_dev" | grep -q .; then
  echo "⚠️  Dev container not running — CI will enforce. Commit allowed."
  exit 0
fi

HAS_BACKEND=$(echo "$STAGED_TS" | grep -q '^backend/' && echo 1 || echo 0)
HAS_FRONTEND=$(echo "$STAGED_TS" | grep -q '^frontend/' && echo 1 || echo 0)

# ─── Backend typecheck ───────────────────────────────────────────
if [ "$HAS_BACKEND" = "1" ]; then
  $DOCKER_EXEC sh -c 'cd /app/backend && npx tsc --noEmit 2>&1'
  if [ $? -ne 0 ]; then
    echo "❌ Backend TypeScript compilation failed."
    exit 1
  fi
  echo "✅ Backend typecheck passed."

  # Backend lint
  $DOCKER_EXEC sh -c 'cd /app/backend && npx eslint src --ext .ts --quiet 2>&1'
  if [ $? -ne 0 ]; then
    echo "❌ Backend lint failed."
    exit 1
  fi
  echo "✅ Backend lint passed."
fi

# ─── Frontend typecheck ──────────────────────────────────────────
if [ "$HAS_FRONTEND" = "1" ]; then
  $DOCKER_EXEC sh -c 'cd /app/frontend && npx tsc --noEmit 2>&1'
  if [ $? -ne 0 ]; then
    echo "❌ Frontend TypeScript compilation failed."
    exit 1
  fi
  echo "✅ Frontend typecheck passed."

  # Frontend lint
  $DOCKER_EXEC sh -c 'cd /app/frontend && ESLINT_USE_FLAT_CONFIG=false npx eslint src/ --quiet 2>&1'
  if [ $? -ne 0 ]; then
    echo "❌ Frontend lint failed."
    exit 1
  fi
  echo "✅ Frontend lint passed."
fi

echo "✅ All checks passed."
exit 0
