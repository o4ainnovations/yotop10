# ── YoTop10 Backend Environment Template ──
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# In production, use Docker secrets (mount to /run/secrets/)
# instead of environment variables for all secrets.

# ── REQUIRED: JWT Secret (for admin authentication)
# Generate with: openssl rand -hex 32 (64 characters minimum)
# Production: Use Docker secret at /run/secrets/jwt_secret
JWT_SECRET=change-me-to-a-64-char-hex-secret

# ── Database Connections
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=yotop10
MONGO_USERNAME=yotop10_admin
MONGO_PASSWORD=change-me-to-a-secure-password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-to-a-secure-password
ES_HOST=localhost
ES_PORT=9200
ES_PASSWORD=change-me-to-a-secure-password

# ── Server Configuration
PORT=8000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# ── Internal API URL (for SSR requests)
INTERNAL_API_URL=http://backend:8000/api
