{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "node": true,
    "es6": true
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "no-duplicate-imports": "error",
    "no-restricted-syntax": [
      "error",
      {
        "selector": "CallExpression[callee.name='set'][arguments.length>=3][arguments.2.value='EX']",
        "message": "Use redis.set(key, val, { EX: ttl }) instead of positional redis.set(key, val, 'EX', ttl)"
      },
      {
        "selector": "TSAsExpression[typeAnnotation.type='TSAnyKeyword']",
        "message": "Do not use 'as any'. Use proper type declarations in backend/src/types/ instead."
      },
      {
        "selector": "TSAsExpression[typeAnnotation.typeName.left.name='unknown'][typeAnnotation.typeName.right.name='Record']",
        "message": "Do not use 'as unknown as Record<string, unknown>'. Fix the underlying type instead."
      }
    ],
    "no-restricted-imports": ["error", {
      "patterns": [{
        "group": ["**/routes/*"],
        "message": "Routes directory may only contain express router files"
      }]
    }]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
